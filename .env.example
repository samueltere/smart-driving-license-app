# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: Public URL where this app is hosted.
# Used in invite links and callbacks.
APP_URL="https://hossana-driving-license-services.onrender.com"

# Optional data directory for SQLite and uploads.
# Use /var/data on Render for persistent storage.
DATA_DIR=

# SMTP configuration for Email OTP (example: Gmail SMTP or Brevo SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Optional HTTP email API (recommended for Render free plan).
# Set EMAIL_PROVIDER=brevo and provide BREVO_API_KEY.
EMAIL_PROVIDER=
BREVO_API_KEY=
